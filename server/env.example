# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Serving (optional)
SERVE_FRONTEND=false

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_WINDOW_MS=10000
CHAT_RATE_LIMIT_MAX_REQUESTS=3

# Logging
LOG_LEVEL=info
LOG_REQUESTS=true

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@ustp.edu.ph
SMTP_PASS=your-app-password
SMTP_FROM=USTP TPCO <tpco@ustp.edu.ph>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
