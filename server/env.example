# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080,https://ustp-tpco.ddns.net

# OpenAI Configuration (optional - for chat features)
OPENAI_API_KEY=

# Frontend Serving (optional)
SERVE_FRONTEND=false

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Security Configuration

# Session Secret (generate a random 64-character string)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# JWT Secret (generate a random 64-character string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Token Expiration
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Cookie Secret
COOKIE_SECRET=your-cookie-secret-change-in-production

# Cookie Domain (for production)
COOKIE_DOMAIN=ustp-tpco.ddns.net

# Password Configuration
PASSWORD_MAX_AGE_DAYS=90
REQUIRE_EMAIL_VERIFICATION=true

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@ustp.edu.ph
SMTP_PASS=your-app-password
SMTP_FROM=USTP TPCO <tpco@ustp.edu.ph>

# Frontend URL (for email links)
FRONTEND_URL=https://ustp-tpco.ddns.net

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_WINDOW_MS=10000
CHAT_RATE_LIMIT_MAX_REQUESTS=3

# Logging
LOG_LEVEL=info
LOG_REQUESTS=true

# IP Whitelist (comma-separated, leave empty for no restriction)
IP_WHITELIST=
